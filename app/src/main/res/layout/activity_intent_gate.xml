<?xml version="1.0" encoding="utf-8"?>
<!-- activity_intent_gate.xml — "The Oasis"
     Full-screen immersive intent capture. Dark, forest-like, meditative. -->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gate_bg"
    android:fillViewport="true"
    android:overScrollMode="never">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="@dimen/screen_min_height"
        android:paddingHorizontal="28dp"
        android:paddingTop="72dp"
        android:paddingBottom="40dp">

        <!-- Breathing orb — the living center of the gate -->
        <ImageView
            android:id="@+id/iv_breathing_orb"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/ic_orb"
            android:alpha="0.7"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@id/tv_time" />

        <!-- Time display -->
        <TextView
            android:id="@+id/tv_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="9:41"
            android:textSize="52sp"
            android:fontFamily="@font/dm_serif_display"
            android:textColor="@color/gate_text_primary"
            android:letterSpacing="-0.03"
            android:alpha="0.9"
            app:layout_constraintTop_toBottomOf="@id/iv_breathing_orb"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="20dp" />

        <!-- Greeting -->
        <TextView
            android:id="@+id/tv_greeting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Good morning"
            android:textSize="16sp"
            android:fontFamily="@font/dm_sans"
            android:textColor="@color/gate_text_secondary"
            android:letterSpacing="0.05"
            android:textAllCaps="true"
            app:layout_constraintTop_toBottomOf="@id/tv_time"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="4dp" />

        <!-- Divider line -->
        <View
            android:id="@+id/divider"
            android:layout_width="48dp"
            android:layout_height="1dp"
            android:background="@color/gate_input_border"
            android:alpha="0.5"
            app:layout_constraintTop_toBottomOf="@id/tv_greeting"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="24dp" />

        <!-- Main prompt -->
        <TextView
            android:id="@+id/tv_prompt"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Why are you\nopening your phone?"
            android:textSize="28sp"
            android:fontFamily="@font/dm_serif_display"
            android:textColor="@color/gate_text_primary"
            android:lineSpacingMultiplier="1.2"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/divider"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="20dp" />

        <!-- Subtitle / AI feedback area -->
        <TextView
            android:id="@+id/tv_subtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Be specific. \"I need to check my work email from Ayaan.\""
            android:textSize="13sp"
            android:fontFamily="@font/dm_sans"
            android:textColor="@color/gate_text_secondary"
            android:gravity="center"
            android:lineSpacingMultiplier="1.5"
            app:layout_constraintTop_toBottomOf="@id/tv_prompt"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="8dp" />

        <!-- Suggestion chips -->
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_suggestions"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:chipSpacingHorizontal="8dp"
            app:layout_constraintTop_toBottomOf="@id/tv_subtitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="20dp" />

        <!-- Intent input field -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_intent"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:boxBackgroundColor="@color/gate_input_bg"
            app:boxStrokeColor="@color/gate_input_border"
            app:boxStrokeWidth="1dp"
            app:hintTextColor="@color/gate_text_secondary"
            app:layout_constraintTop_toBottomOf="@id/chip_group_suggestions"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="16dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_intent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/gate_hint"
                android:inputType="textCapSentences|textMultiLine"
                android:imeOptions="actionDone"
                android:maxLines="3"
                android:textColor="@color/gate_text_primary"
                android:textColorHint="@color/gate_text_secondary"
                android:textSize="16sp"
                android:fontFamily="@font/dm_sans"
                android:paddingVertical="16dp"
                android:paddingHorizontal="16dp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Char hint -->
        <TextView
            android:id="@+id/tv_char_hint"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/gate_char_hint"
            android:textSize="12sp"
            android:textColor="@color/nudge_level1"
            android:fontFamily="@font/dm_sans"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/til_intent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="4dp" />

        <!-- AI feedback (shown briefly) -->
        <TextView
            android:id="@+id/tv_ai_feedback"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="@color/nudge_level1"
            android:fontFamily="@font/dm_sans"
            android:gravity="center"
            android:lineSpacingMultiplier="1.4"
            android:visibility="gone"
            android:padding="12dp"
            android:background="@drawable/bg_feedback_pill"
            app:layout_constraintTop_toBottomOf="@id/til_intent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="8dp" />

        <!-- Loading group (AI processing indicator) -->
        <LinearLayout
            android:id="@+id/loading_group"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/til_intent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="12dp">

            <ProgressBar
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:indeterminateTint="@color/sage_green_light" />

            <TextView
                android:id="@+id/tv_loading_message"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/gate_ai_thinking"
                android:textSize="13sp"
                android:textColor="@color/gate_text_secondary"
                android:fontFamily="@font/dm_sans"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <!-- Proceed button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_proceed"
            style="@style/Widget.FocusGate.Button.Primary"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:text="@string/gate_proceed_button"
            android:enabled="false"
            android:alpha="0.4"
            app:layout_constraintTop_toBottomOf="@id/loading_group"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="20dp" />

        <!-- Work Mode shortcut -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_start_work_mode"
            style="@style/Widget.FocusGate.Button.Secondary"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:text="@string/gate_work_mode_label"
            app:strokeColor="@color/gate_input_border"
            android:textColor="@color/gate_text_secondary"
            app:layout_constraintTop_toBottomOf="@id/btn_proceed"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="12dp" />

        <!-- Emergency / exempt -->
        <TextView
            android:id="@+id/btn_emergency"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Emergency bypass"
            android:textSize="12sp"
            android:textColor="@color/gate_text_secondary"
            android:fontFamily="@font/dm_sans"
            android:paddingVertical="12dp"
            android:alpha="0.5"
            app:layout_constraintTop_toBottomOf="@id/btn_start_work_mode"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="8dp" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
