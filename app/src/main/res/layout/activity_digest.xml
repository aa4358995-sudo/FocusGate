<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="60dp"
        android:paddingBottom="40dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FOCUS DIGEST"
            android:textSize="11sp"
            android:fontFamily="@font/dm_sans"
            android:textColor="@color/sage_green"
            android:letterSpacing="0.15"
            android:textAllCaps="true" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Here's what you missed"
            android:textSize="26sp"
            android:fontFamily="@font/dm_serif_display"
            android:textColor="@color/charcoal"
            android:layout_marginTop="4dp" />

        <!-- Duration badge -->
        <TextView
            android:id="@+id/tv_session_duration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="25m session"
            android:textSize="14sp"
            android:fontFamily="@font/dm_sans"
            android:textColor="@color/text_secondary"
            android:background="@drawable/bg_duration_badge"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:layout_marginTop="10dp" />

        <!-- Loading state -->
        <LinearLayout
            android:id="@+id/loading_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingVertical="60dp">

            <ProgressBar
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:indeterminateTint="@color/sage_green" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Summarizing what you missed…"
                android:textSize="14sp"
                android:fontFamily="@font/dm_sans"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="12dp" />
        </LinearLayout>

        <!-- Content (hidden while loading) -->
        <LinearLayout
            android:id="@+id/content_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Congratulations message -->
            <TextView
                android:id="@+id/tv_congrats_message"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Well done. You chose depth over distraction."
                android:textSize="15sp"
                android:fontFamily="@font/dm_sans"
                android:textColor="@color/sage_green_dark"
                android:background="@drawable/bg_congrats_card"
                android:padding="16dp"
                android:layout_marginTop="20dp"
                android:lineSpacingMultiplier="1.4" />

            <!-- Headline -->
            <TextView
                android:id="@+id/tv_headline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="8 messages, nothing urgent"
                android:textSize="20sp"
                android:fontFamily="@font/dm_serif_display"
                android:textColor="@color/charcoal"
                android:layout_marginTop="24dp"
                android:lineSpacingMultiplier="1.3" />

            <!-- Detailed summary -->
            <TextView
                android:id="@+id/tv_detailed_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:fontFamily="@font/dm_sans"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="8dp"
                android:lineSpacingMultiplier="1.5" />

            <!-- Stats row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="20dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    style="@style/Widget.FocusGate.Card">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">
                        <TextView
                            android:id="@+id/tv_notification_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 intercepted"
                            android:textSize="16sp"
                            android:fontFamily="@font/dm_serif_display"
                            android:textColor="@color/sage_green_dark" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Notifications"
                            android:textSize="11sp"
                            android:fontFamily="@font/dm_sans"
                            android:textColor="@color/text_secondary" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    style="@style/Widget.FocusGate.Card">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">
                        <TextView
                            android:id="@+id/tv_focus_time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="25m"
                            android:textSize="16sp"
                            android:fontFamily="@font/dm_serif_display"
                            android:textColor="@color/sage_green_dark" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Focused"
                            android:textSize="11sp"
                            android:fontFamily="@font/dm_sans"
                            android:textColor="@color/text_secondary" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- Urgent card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_urgent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFF5EC">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚑  Needs Your Attention"
                        android:textSize="13sp"
                        android:fontFamily="@font/dm_sans_medium"
                        android:textColor="@color/terracotta" />
                    <TextView
                        android:id="@+id/tv_urgent_items"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:fontFamily="@font/dm_sans"
                        android:textColor="@color/earth_brown_dark"
                        android:layout_marginTop="8dp"
                        android:lineSpacingMultiplier="1.5" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Work card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_work"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:visibility="gone"
                style="@style/Widget.FocusGate.Card">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="4dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Work"
                        android:textSize="13sp"
                        android:fontFamily="@font/dm_sans_medium"
                        android:textColor="@color/text_primary" />
                    <TextView
                        android:id="@+id/tv_work_items"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:fontFamily="@font/dm_sans"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="6dp"
                        android:lineSpacingMultiplier="1.5" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Social card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_social"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:visibility="gone"
                style="@style/Widget.FocusGate.Card">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="4dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Social"
                        android:textSize="13sp"
                        android:fontFamily="@font/dm_sans_medium"
                        android:textColor="@color/text_primary" />
                    <TextView
                        android:id="@+id/tv_social_items"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:fontFamily="@font/dm_sans"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="6dp"
                        android:lineSpacingMultiplier="1.5" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- Action buttons -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_start_another"
            style="@style/Widget.FocusGate.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Start Another Session"
            android:layout_marginTop="32dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_done"
            style="@style/Widget.FocusGate.Button.Ghost"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Back to Dashboard"
            android:layout_marginTop="8dp" />

    </LinearLayout>
</ScrollView>
